# hyper = ctrl + shift + alt + cmd (Caps Lock via Karabiner)
#
# NOTE: when testing Aerospace, uncomment the AEROSPACE section
# and comment out the YABAI section. Aerospace handles its own
# focus/move/resize/workspace binds natively.

## --- YABAI (commented out during Aerospace test) ---

# hyper - h : yabai -m window --focus west
# hyper - j : yabai -m window --focus south
# hyper - k : yabai -m window --focus north
# hyper - l : yabai -m window --focus east

# ctrl + alt - h : yabai -m window --warp west
# ctrl + alt - j : yabai -m window --warp south
# ctrl + alt - k : yabai -m window --warp north
# ctrl + alt - l : yabai -m window --warp east

# hyper - left  : yabai -m window --resize left:-50:0  || yabai -m window --resize right:-50:0
# hyper - right : yabai -m window --resize right:50:0  || yabai -m window --resize left:50:0
# hyper - up    : yabai -m window --resize top:0:-50   || yabai -m window --resize bottom:0:-50
# hyper - down  : yabai -m window --resize bottom:0:50 || yabai -m window --resize top:0:50

# hyper - f : yabai -m window --toggle zoom-fullscreen
# hyper - space : yabai -m window --toggle float; yabai -m window --grid 4:4:1:1:2:2
# hyper - r : yabai -m space --rotate 90
# hyper - 0x18 : yabai -m space --balance

# hyper - q : ~/.config/skhd/reload-wm.sh

## --- AEROSPACE (active) ---
# focus/move/resize/workspaces handled by Aerospace natively
hyper - q : aerospace reload-config; sketchybar --reload

## --- ALWAYS ACTIVE ---

# tmux splits
hyper - v : tmux split-window -h -c "#{pane_current_path}"
hyper - s : tmux split-window -v -c "#{pane_current_path}"

[user]
	name = Niro Åhman
	email = niro@niro.fi

[core]
	editor = nvim
[sequence]
	editor = interactive-rebase-tool
	autocrlf = input
	hooksPath = ~/.config/git/hooks
	excludesfile = ~/.gitignore_global

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	autoSetupRemote = true

[merge]
	tool = fugitive
	conflictstyle = merge

[mergetool]
	keepBackup = false

[mergetool "nvimdiff2"]
	cmd = nvim -d $LOCAL $MERGED -c 'wincmd l' -c 'norm ]c'

[mergetool "fugitive"]
	cmd = nvim -c "Gvdiffsplit!" "$MERGED"

[alias]
	st = status
	co = checkout
	br = branch
	lg = log --oneline --graph --decorate --all

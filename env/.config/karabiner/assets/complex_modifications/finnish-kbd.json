{
  "title": "Finnish keyboard fixes",
  "rules": [
    {
      "description": "Swap < > and ` ~ keys",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "grave_accent_and_tilde", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "non_us_backslash", "repeat": true }]
        },
        {
          "type": "basic",
          "from": { "key_code": "non_us_backslash", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "grave_accent_and_tilde", "repeat": true }]
        }
      ]
    }
  ]
}

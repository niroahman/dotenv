{
  "title": "Tab → Tmux Prefix (held) / Tab (tapped)",
  "rules": [
    {
      "description": "Tab → Ctrl+A (held) / Tab (tapped)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "tab",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            {
              "key_code": "a",
              "modifiers": ["left_control"]
            }
          ],
          "to_if_alone": [
            { "key_code": "tab" }
          ]
        }
      ]
    }
  ]
}
